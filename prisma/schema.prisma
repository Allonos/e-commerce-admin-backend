generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  vehicles  Vehicle[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Make {
  id       String    @id @default(uuid())
  name     String    @unique
  models   Model[]
  vehicles Vehicle[]
}

model Model {
  id       String    @id @default(uuid())
  name     String
  makeId   String
  make     Make      @relation(fields: [makeId], references: [id])
  vehicles Vehicle[]
}

model Type {
  id       String    @id @default(uuid())
  name     String    @unique
  vehicles Vehicle[]
}

model Hero {
  id        String   @id @default(uuid())
  tagLine   String
  subtitle  String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Transmission {
  AUTOMATIC
  MANUAL
  SEMI_AUTOMATIC
  CVT
}

enum FuelType {
  GASOLINE
  DIESEL
  ELECTRIC
  HYBRID
  PLUG_IN_HYBRID
  LPG
  CNG
  HYDROGEN
}

enum VehicleCondition {
  NEW
  USED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
  SOLD
}

model Vehicle {
  id           String           @id @default(uuid())
  makeId       String
  make         Make             @relation(fields: [makeId], references: [id])
  modelId      String
  model        Model            @relation(fields: [modelId], references: [id])
  typeId       String
  type         Type             @relation(fields: [typeId], references: [id])
  year         Int
  lot          String           @unique @db.VarChar(255)
  price        Float
  images       String[]
  location     String           @db.VarChar(255)
  status       String           @default("active")
  isFeatured   Boolean          @default(false)
  views        Int              @default(0)
  userId       String
  user         User             @relation(fields: [userId], references: [id])
  priority     Int              @default(0)
  mileage      Int              @default(0)
  engine       Int              @default(0)
  transmission Transmission     @default(AUTOMATIC)
  condition    VehicleCondition @default(USED)
  fuelType     FuelType         @default(GASOLINE)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}
