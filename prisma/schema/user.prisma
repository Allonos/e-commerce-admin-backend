enum UserRole {
  USER
  DEALER
  ADMIN
}

enum AdminRole {
  MAIN
  CONTENT
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  password     String
  role         UserRole   @default(USER)
  adminRole    AdminRole?
  isBanned     Boolean    @default(false)
  bannedAt     DateTime?
  bannedReason String?
  vehicles     Vehicle[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
